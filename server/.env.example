PORT=8787
CORPUS_DIR=./corpus

# Auth (per-user history + stats). Leave AUTH_SECRET as the default and the
# server runs with a dev secret. Set both for production.
AUTH_DB=./data/auth.sqlite
AUTH_SECRET=dev-secret-change-me

# Each adapter is independent. Leave a key blank to skip that provider.
# These are server-side fallbacks — clients (extension, Mac app) can also send
# their own keys per-request (BYOK), and those win over the env values.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
TOGETHER_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=
MOONSHOT_API_KEY=
MINIMAX_API_KEY=
