{
  "manifest_version": 3,
  "name": "Qrammerly",
  "version": "0.2.0",
  "description": "Multi-model AI proofreading inside any text field. BYOK.",
  "permissions": ["storage", "activeTab", "scripting", "nativeMessaging"],
  "host_permissions": ["http://localhost:8787/*", "https://*/*", "http://*/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Qrammerly"
  }
}
